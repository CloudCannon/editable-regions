<section class="env-vars">
	<h2>Environment variables</h2>
	<dl>
		<dt>NODE_ENV (allowlist)</dt>
		<dd>{{ process.env.NODE_ENV }}</dd>
		<dt>PUBLIC_SITE_NAME (PUBLIC_ prefix)</dt>
		<dd>{{ process.env.PUBLIC_SITE_NAME }}</dd>
		<dt>PUBLIC_API_BASE (PUBLIC_ prefix)</dt>
		<dd>{{ process.env.PUBLIC_API_BASE }}</dd>
	</dl>
	<p>
		Run with e.g.
		<code>PUBLIC_SITE_NAME=Demo PUBLIC_API_BASE=https://api.example.com npx @11ty/eleventy</code>
		to see values render here. Anything not listed in <code>env</code> or
		matching <code>envPrefix</code> is invisible to the bundle.
	</p>
</section>
