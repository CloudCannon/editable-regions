<section class="post-list">
	<h2>Posts</h2>
	<ul>
		{% for post in collections.posts %}
			<li>
				<a href="{{ post.url }}">{{ post.data.title }}</a>
				<time datetime="{{ post.date | dateToRfc3339 }}">
					{{ post.date | htmlDateString }}
				</time>
			</li>
		{% endfor %}
	</ul>
	<p>Newest post: {{ collections.posts | getNewestCollectionItemDate | dateToRfc822 }}</p>
</section>
