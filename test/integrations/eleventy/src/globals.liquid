---
title: Globals
layout: page-shell
date: 2026-04-21
---
<section class="eleventy-globals">
	<h2>eleventy</h2>
	<dl>
		<dt>eleventy.version</dt><dd>{{ eleventy.version }}</dd>
		<dt>eleventy.generator</dt><dd>{{ eleventy.generator }}</dd>
		<dt>eleventy.env.runMode</dt><dd>{{ eleventy.env.runMode }}</dd>
		<dt>eleventy.env.source</dt><dd>{{ eleventy.env.source }}</dd>
		<dt>eleventy.directories.input</dt><dd>{{ eleventy.directories.input }}</dd>
		<dt>eleventy.directories.includes</dt><dd>{{ eleventy.directories.includes }}</dd>
		<dt>eleventy.directories.output</dt><dd>{{ eleventy.directories.output }}</dd>
	</dl>
</section>

<section class="page-globals">
	<h2>page</h2>
	<dl>
		<dt>inputPath</dt><dd>{{ page.inputPath }}</dd>
		<dt>fileSlug</dt><dd>{{ page.fileSlug }}</dd>
		<dt>filePathStem</dt><dd>{{ page.filePathStem }}</dd>
		<dt>outputFileExtension</dt><dd>{{ page.outputFileExtension }}</dd>
		<dt>url</dt><dd>{{ page.url }}</dd>
		<dt>outputPath</dt><dd>{{ page.outputPath }}</dd>
		<dt>date (RFC 3339)</dt><dd>{{ page.date | dateToRfc3339 }}</dd>
	</dl>
</section>

<section class="env-vars">
	<h2>process.env</h2>
	<dl>
		<dt>NODE_ENV (allowlist)</dt><dd>{{ process.env.NODE_ENV }}</dd>
		<dt>PUBLIC_SITE_NAME (PUBLIC_ prefix)</dt><dd>{{ process.env.PUBLIC_SITE_NAME }}</dd>
		<dt>PUBLIC_API_BASE (PUBLIC_ prefix)</dt><dd>{{ process.env.PUBLIC_API_BASE }}</dd>
	</dl>
</section>

<section class="collections">
	<h2>collections.posts</h2>
	<ul>
		{% for post in collections.posts %}
			<li>
				<a href="{{ post.url }}">{{ post.data.title }}</a>
				<time datetime="{{ post.date | dateToRfc3339 }}">{{ post.date | htmlDateString }}</time>
				<small>(slug: {{ post.fileSlug }}, stem: {{ post.filePathStem }})</small>
			</li>
		{% endfor %}
	</ul>
	<p>Newest post date: {{ collections.posts | getNewestCollectionItemDate | dateToRfc822 }}</p>
	<p>Current item (via getCollectionItem, expects to match this page): {% assign current = collections.posts | getCollectionItem: page %}{{ current.data.title | default: "(none — this isn't in the posts collection)" }}</p>
</section>
