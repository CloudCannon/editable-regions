---
import SvelteCounter from "../components/svelte-counter.svelte";
import SvelteStatic from "../components/svelte-static.svelte";
import SvelteTest from "../components/svelte-test.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Svelte Integration Test</title>
    <script>
      import("../../live-editing");
    </script>
  </head>
  <body>
    <h1>Svelte Integration Tests</h1>

    <section>
      <h2>Top-level Svelte — static (no directive)</h2>
      <SvelteStatic title="Top-level static" />
    </section>

    <section>
      <h2>Top-level Svelte — client:load</h2>
      <SvelteCounter label="Top-level client:load" client:load />
    </section>

    <section>
      <h2>Top-level Svelte — client:idle</h2>
      <SvelteCounter label="Top-level client:idle" client:idle />
    </section>

    <section>
      <h2>Top-level Svelte — client:visible</h2>
      <SvelteCounter label="Top-level client:visible" client:visible />
    </section>

    <section>
      <h2>Svelte inside Astro component</h2>
      <div data-editable="component" data-component="svelte-test">
        <SvelteTest />
      </div>
    </section>

    <section>
      <h2>Editable Svelte components</h2>
      <div data-editable="component" data-component="svelte-counter">
        <SvelteCounter label="Editable counter" client:load />
      </div>
      <div data-editable="component" data-component="svelte-static">
        <SvelteStatic title="Editable static" />
      </div>
    </section>
  </body>
</html>
