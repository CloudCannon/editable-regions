---
import { Image } from "astro:assets";

interface Props {
  src?: string;
  alt?: string;
  width?: number;
  height?: number;
}

const { src = "/test-image.png", alt = "Test image", width = 100, height = 100 } = Astro.props;
---

<div class="assets-image">
  <Image src={src} alt={alt} width={width} height={height} />
</div>
