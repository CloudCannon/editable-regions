// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`a component with a slot renders its shell gracefully when no child is provided 1`] = `"<div data-v-app=""><div class="slot-shell"></div></div>"`;

exports[`a registered component passes slot content to a child component 1`] = `"<div data-v-app=""><div class="slot-parent"><div class="slot-shell"><p class="slotted">slotted from parent</p></div></div></div>"`;
